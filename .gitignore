# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Project artifacts (model weights, raw crawls). Eval baselines live under
# `artifacts/evals/` and ARE committed so MODEL_CARD numbers are reproducible.
artifacts/qwen-civic-*/
artifacts/gemma-civic-*/
artifacts/*.bin
artifacts/*.safetensors
artifacts/*.gguf
artifacts/*-mlx-q4/
artifacts/*-gguf-q5km/
# Per-jurisdiction pipeline outputs (PR #49): {slug}-cpt/, -cpt-fused/, -sft/,
# -v1-fused/, -pipeline/. Adapters/weights stay local; status.json + configs
# are also per-run scratch.
artifacts/*-cpt/
artifacts/*-cpt-fused/
artifacts/*-sft/
artifacts/*-v1-fused/
artifacts/*-pipeline/
data/raw/**
!data/raw/manifest.jsonl
!data/raw/.gitkeep
data/processed/**
!data/processed/.gitkeep
# `civic-slm eval seed` writes to `.staged-{bench}.jsonl` for human review
# before promoting into the canonical bench. Don't commit until reviewed.
data/eval/.staged-*.jsonl
# Sidecar files produced by analysis scripts (`scripts/tag_eval_jurisdictions.py`).
# Regenerable; kept out of the corpus state.
data/eval/.jurisdiction-tags.jsonl

# Secrets
.env
.envrc

# Tooling
wandb/
.DS_Store

# Editors
.vscode/
.idea/

# v1 fused artifact (full weights — too large for git, regenerable via
# `mlx_lm.fuse --model <cpt-fused> --adapter-path artifacts/qwen-civic-sft`).
artifacts/*-fused/
# Training and eval logs (regenerable; keep status reports tracked though).
artifacts/training-logs/cpt-*.log
artifacts/training-logs/sft-*.log
artifacts/training-logs/synth.log
artifacts/training-logs/fuse-*.log
artifacts/training-logs/process.log
artifacts/training-logs/quantize-*.log
artifacts/training-logs/v1-server.log
artifacts/training-logs/v1-*.log
artifacts/training-logs/crawl-*.log

# SFT synth outputs (regenerable via `civic-slm synth <jurisdiction>`).
# Untracked so re-runs don't litter `git status`; commit explicitly with -f
# if you want a particular dataset preserved.
data/sft/
