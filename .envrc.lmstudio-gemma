# Sourcing target for a fully-local LM Studio + Gemma 4 31B run.
# Usage: `set -a; source .envrc.lmstudio-gemma; set +a` (or `direnv allow` if you wire it up).

# Fully local — no Anthropic. STRICT_LOCAL raises if anything tries to call out.
export CIVIC_SLM_LLM_BACKEND=local
export CIVIC_SLM_STRICT_LOCAL=1

# Synth + judge: route through LM Studio's OpenAI-compatible endpoint.
export CIVIC_SLM_LOCAL_LLM_URL=http://127.0.0.1:1234
export CIVIC_SLM_LOCAL_LLM_MODEL=gemma-4-31b-it-mlx

# Candidate model (eval target / web playground): same server, same model.
export CIVIC_SLM_CANDIDATE_URL=http://127.0.0.1:1234/v1
export CIVIC_SLM_CANDIDATE_MODEL=gemma-4-31b-it-mlx

# Teacher (side-by-side comparator). Reuse the same server until we get a
# bigger model loaded. Qwen 3.6 27B is the closest "bigger candidate" loaded.
export CIVIC_SLM_TEACHER_URL=http://127.0.0.1:1234/v1
export CIVIC_SLM_TEACHER_MODEL=qwen3.6-27b-ud-mlx

# Web playground slot bindings.
export CIVIC_SLM_GEMMA_MODEL=gemma-4-31b-it-mlx
export CIVIC_SLM_CIVIC_MODEL=gemma-4-31b-it-mlx  # placeholder until v1 ships
