# Sourcing target for a fully-local civic-slm run against LM Studio.
# Usage: `set -a; source .envrc.lmstudio; set +a` (or `direnv allow` if you wire it up).
#
# Assumes LM Studio's developer server is up on :1234 with at least
# `qwen3.6-27b-ud-mlx` loaded. Load `gemma-4-31b-it-mlx` too if you want to
# run side-by-side against the default `comparator-gemma-4-31b` label.

# Fully local — no Anthropic. STRICT_LOCAL raises if anything tries to call out.
export CIVIC_SLM_LLM_BACKEND=local
export CIVIC_SLM_STRICT_LOCAL=1

# The two — and only two — model-config env vars in this project.
#
#   CIVIC_SLM_LM_STUDIO_URL : where LM Studio's /v1/chat/completions lives.
#   CIVIC_SLM_DEFAULT_MODEL : project-side label (NOT a served name).
#                             Resolves through src/civic_slm/serve/models.py
#                             to the actual served model. Add new models in
#                             that registry, not here.
export CIVIC_SLM_LM_STUDIO_URL=http://127.0.0.1:1234
export CIVIC_SLM_DEFAULT_MODEL=base-qwen3.6-27b
