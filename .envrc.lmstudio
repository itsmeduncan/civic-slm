# Sourcing target for a fully-local civic-slm run against LM Studio.
# Usage: `set -a; source .envrc.lmstudio; set +a` (or `direnv allow` if you wire it up).
#
# Assumes LM Studio's developer server is up on :1234 with at least
# `qwen3.6-27b-ud-mlx` loaded. `gemma-4-31b-it-mlx` is the alternate slot
# used by the web playground.

# Fully local — no Anthropic. STRICT_LOCAL raises if anything tries to call out.
export CIVIC_SLM_LLM_BACKEND=local
export CIVIC_SLM_STRICT_LOCAL=1

# Synth + judge: route through LM Studio's OpenAI-compatible endpoint.
export CIVIC_SLM_LOCAL_LLM_URL=http://127.0.0.1:1234
export CIVIC_SLM_LOCAL_LLM_MODEL=qwen3.6-27b-ud-mlx

# Candidate model (eval target / web playground): the project base.
export CIVIC_SLM_CANDIDATE_URL=http://127.0.0.1:1234
export CIVIC_SLM_CANDIDATE_MODEL=qwen3.6-27b-ud-mlx

# Teacher (side-by-side comparator). Multi-hosted on the same LM Studio
# server; differ only by model id.
export CIVIC_SLM_TEACHER_URL=http://127.0.0.1:1234
export CIVIC_SLM_TEACHER_MODEL=qwen3.6-27b-ud-mlx

# Web playground slot bindings.
export CIVIC_SLM_GEMMA_MODEL=gemma-4-31b-it-mlx
export CIVIC_SLM_CIVIC_MODEL=qwen3.6-27b-ud-mlx   # placeholder until v1 ships
